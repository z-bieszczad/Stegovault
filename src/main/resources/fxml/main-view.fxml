<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.stegovault.controller.MainController"
      fx:id="rootPane"
      spacing="0"
      alignment="CENTER"
      prefWidth="500"
      prefHeight="400"
      style="-fx-padding: 40;">

    <Label text="StegoVault" styleClass="label-title"/>
    <Label text="Hide encrypted messages inside images" styleClass="label-subtitle"/>

    <Region prefHeight="32"/>

    <HBox spacing="16" alignment="CENTER">

        <VBox styleClass="card" spacing="8" alignment="CENTER"
              onMouseClicked="#onEmbed" prefWidth="250">
            <Label text="Embed" styleClass="label-card-title"/>
            <Label text="Hide a message&#10;inside an image"
                   styleClass="label-subtitle" textAlignment="CENTER"/>
        </VBox>

        <VBox styleClass="card" spacing="8" alignment="CENTER"
              onMouseClicked="#onExtract" prefWidth="250">
            <Label text="Extract" styleClass="label-card-title"/>
            <Label text="Reveal a message&#10;from an image"
                   styleClass="label-subtitle" textAlignment="CENTER"/>
        </VBox>

    </HBox>

    <Region prefHeight="24"/>

    <Button fx:id="themeBtn" text="Light mode"
            styleClass="button-ghost" onAction="#onToggleTheme"/>

</VBox>
