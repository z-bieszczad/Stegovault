<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.stegovault.controller.ExtractController"
      fx:id="rootPane"
      spacing="10"
      prefWidth="500"
      prefHeight="440"
      style="-fx-padding: 32;">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="← Back" styleClass="button-ghost" onAction="#onBack"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Extract Message" styleClass="label-title"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <Separator/>

    <Label text="CARRIER IMAGE" styleClass="label-section"/>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="imagePathField"
                   promptText="No file selected"
                   editable="false"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Browse" onAction="#onChooseImage"/>
    </HBox>

    <Label text="PASSWORD" styleClass="label-section"/>
    <PasswordField fx:id="passwordField"
                   promptText="Enter password"/>
    <Label fx:id="passwordHint"
           text="Min 8 chars · uppercase · lowercase · digit"
           styleClass="label-subtitle"/>

    <Button text="EXTRACT"
            onAction="#onExtract"
            styleClass="button-primary"
            maxWidth="Infinity"/>

    <ProgressBar fx:id="progressBar"
                 prefHeight="6"
                 progress="0"
                 visible="false"
                 managed="false"/>

    <Label fx:id="statusLabel"/>

    <Label text="OUTPUT" styleClass="label-section"/>
    <TextArea fx:id="outputArea"
              prefHeight="120"
              wrapText="true"/>
    <Button text="COPY" onAction="#onCopyResult"
            styleClass="button-ghost"/>

</VBox>

